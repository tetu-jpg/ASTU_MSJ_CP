n=int(input())
for _ in range(n):
    t=int(input())
    a=list(map(int,input().split()))
    count=0
    l=0
    r=t-1
    while l<r:
        if a[l]==1 and a[r]==0:
            count+=1
            l+=1
            r-=1
        else:
            if a[l]==0:
                l+=1
            if a[r]==1:
                r-=1
    print(count)
