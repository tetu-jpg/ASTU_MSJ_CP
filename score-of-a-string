class Solution(object):
    def scoreOfString(self, s):
        """
        :type s: str
        :rtype: int
        """
        n=len(s)
        sum=0
        for i in range(n-1):
            cu=s[i]
            ne=s[i+1]
            nu=abs(ord(cu)-ord(ne))
            sum +=nu
        return sum
            
        
