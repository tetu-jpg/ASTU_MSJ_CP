class Solution:
    def longestAlternatingSubarray(self, nums: List[int], threshold: int) -> int:
        ans = 0
        n = len(nums)

        for i in range(n):
            if nums[i] % 2 == 1 or nums[i] > threshold:
                continue

            length = 1

            for j in range(i + 1, n):
                if nums[j] > threshold:
                    break

                if nums[j] % 2 != nums[j - 1] % 2:
                    length += 1
                else:
                    break

            ans = max(ans, length)

        return ans
