class Solution(object):
    def countPairs(self, nums, target):
        """
        :type nums: List[int]
        :type target: int
        :rtype: int
        """
        count=0
        r=len(nums)
        for i in range(r):
            x=i+1
            for j in range(x,r):
                if nums[i]+nums[j] < target:
                   count+=1
        return count
              
        
