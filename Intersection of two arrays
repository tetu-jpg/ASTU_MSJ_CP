class Solution(object):
    def intersection(self, nums1, nums2):
        """
        :type nums1: List[int]
        :type nums2: List[int]
        :rtype: List[int]
        """
        ls=[]
        n=len(nums1)
        m=len(nums2)
        for i in range(n):
            for j in range(m):
                if nums1[i]==nums2[j]:
                   ls.append(nums1[i])
        l=set(ls)
        lu=list(l)
        return lu
        
