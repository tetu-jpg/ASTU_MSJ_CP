class Solution(object):
    def groupAnagrams(self, strs):
        d = len(strs)

        
        sor = []
        for i in strs:
            sor.append(sorted(i))

        visited = [False] * d
        ss = []

        
        for i in range(d):
            if visited[i]:
                continue

            r = []
            r.append(strs[i])
            visited[i] = True

            for j in range(i + 1, d):
                if sor[i] == sor[j]:
                    r.append(strs[j])
                    visited[j] = True

            ss.append(r)

        return ss
