class Solution(object):
    def twoSum(self, nums, target):
        """
        :type nums: List[int]
        :type target: int
        :rtype: List[int]
        """
        n=len(nums)
        for i in range(n):
            x=i+1
            for j in range(x,n):
                sum=nums[i]+nums[j]
                if sum == target:
                    return [i,j]
