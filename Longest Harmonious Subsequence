class Solution:
    def findLHS(self, nums):
        d = {}

        for x in nums:
            if x in d:
                d[x] += 1
            else:
                d[x] = 1

        ans = 0

        for x in d:
            if x + 1 in d:
                ans = max(ans, d[x] + d[x + 1])

        return ans
