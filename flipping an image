class Solution(object):
    def flipAndInvertImage(self, image):
        """
        :type image: List[List[int]]
        :rtype: List[List[int]]
        """
        row=len(image)
        for i in image:
            i.reverse()
        for i in range(row):
            for j in range(row):
                if image[i][j]==1:
                    image[i][j]=0
                else:
                    image[i][j]=1
        return image

        
            

        
