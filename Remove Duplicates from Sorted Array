class Solution(object):
    def removeDuplicates(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        k=1
        d=len(nums)
        for i in range(1,d):
            if nums[i]!=nums[k-1]:
                nums[k]=nums[i]
                k+=1
        
        return k
            
            
