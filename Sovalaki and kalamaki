t = int(input()) 

for _  in range(t): 
    n = int(input())
    do = list(map(int, input().split()))

    do.sort()
    can = True
    for i in range(1 ,n-1, 1):
        if do[i] != do[i+1]:
            can = False
            break
            
    if can:
        print("YES")
    else: 
        print("NO")
